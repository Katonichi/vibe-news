# ============================================================
# Vibe News - 環境変数設定
# ============================================================
# このファイルをコピーして .env.development / .env.production を作成してください
#   cp .env.example .env.development
#   cp .env.example .env.production
# ============================================================

# アプリケーションモード (development | production)
VITE_APP_MODE=development

# Gemini API Key
# Google AI Studio (https://aistudio.google.com/) で取得
# 開発時のみ .env に設定すると、画面のAPIキー入力欄に自動入力されます
# 本番環境では空にし、ユーザーが画面から入力する運用を推奨
VITE_GEMINI_API_KEY=

# Gemini テキスト生成モデル
VITE_GEMINI_MODEL=gemini-2.5-flash

# Gemini TTS モデル
VITE_TTS_MODEL=gemini-2.5-flash-preview-tts
